# Server Configuration
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Database Configuration
POSTGRES_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/cutthecrap_dev

# Frontend Configuration
FRONTEND_URL=http://localhost:8081

# WorkOS Configuration
WORKOS_CLIENT_ID=client_your_id_here
WORKOS_API_KEY=sk_test_your_key_here
WORKOS_REDIRECT_URI=https://cutthecrap.deploy-box.com/api/v1/auth/callback

# ChatGPT Azure Function
CHATGPT_API_BASE=https://deploy-box-apis-func-dev.azurewebsites.net
DEPLOY_BOX_CLIENT_ID=your-base64-encoded-client-id
DEPLOY_BOX_CLIENT_SECRET=your-client-secret
# OPENAI_API_KEY=sk-... (deprecated – use client credentials above)

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_PRO_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_PRO_YEARLY=price_your_yearly_price_id
STRIPE_PRICE_PRO_LIFETIME=price_your_lifetime_price_id

# Apple App Store Billing
APPLE_BUNDLE_ID=com.yourcompany.cutthecrap
APPLE_SHARED_SECRET=your_apple_shared_secret
APPLE_ISSUER_ID=your_apple_issuer_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key_base64

# Google Play Billing
GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.cutthecrap
GOOGLE_SERVICE_ACCOUNT_JSON=your_service_account_json_base64

# CORS Configuration
CORS_ORIGIN=http://localhost:19006,http://localhost:19000,http://localhost:8081
