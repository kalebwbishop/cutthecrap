# Copy this file to terraform.tfvars and fill in real values.
# Never commit terraform.tfvars to source control.

# ssh_public_key_path = "~/.ssh/id_rsa.pub"
# location            = "eastus"
# vm_size             = "Standard_B2s"

# workos_api_key   = "sk_live_..."
# workos_client_id = "client_..."
# deploy_box_client_id     = "base64-encoded-client-id"
# deploy_box_client_secret = "your-client-secret"
# chatgpt_api_base = "https://your-function-app.azurewebsites.net"

# TLS certificates (generated by renew-cert.ps1 into certs/)
# tls_fullchain_path = "../certs/fullchain.pem"
# tls_privkey_path   = "../certs/privkey.pem"
